{
  "name": "dtrack-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for OWASP Dependency-Track.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dependency-track",
    "owasp",
    "sbom",
    "vulnerability"
  ],
  "homepage": "https://github.com/msiemens/dtrack-mcp#readme",
  "bugs": {
    "url": "https://github.com/msiemens/dtrack-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msiemens/dtrack-mcp.git"
  },
  "license": "MIT",
  "author": "Markus Siemens <markus@m-siemens.de>",
  "type": "module",
  "bin": {
    "dtrack-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
